# =========================================================================
# Uprising App — environment variables
# Copy to .env.local for local dev. Set the same in Vercel for production.
# NEVER commit .env.local to git.
# =========================================================================

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Shopify -----
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10
SHOPIFY_WEBHOOK_SECRET=

# ----- Klaviyo -----
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_REVISION=2025-01-15

# ----- App config -----
APP_URL=http://localhost:3000
